# ──────────────────────────────────────────────
# TusCoach — Environment Variables
# Copy to .env and fill in values.
# ──────────────────────────────────────────────

# ── Application ──
APP_NAME=TusCoach
APP_VERSION=0.1.0
ENV=dev                           # dev | prod

# ── Database (PostgreSQL) ──
# Dev default uses Docker Compose on port 5433.
DATABASE_URL=postgresql://tuscoach:tuscoach123@localhost:5433/tuscoach

# ── Redis / Celery broker ──
REDIS_URL=redis://localhost:6379/0

# ── Authentication ──
# IMPORTANT: In production generate a strong secret:
#   openssl rand -hex 32
JWT_SECRET=dev-secret-change-in-production
JWT_ALG=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ── LLM ──
LLM_PROVIDER=openai
LLM_API_KEY=                      # Required for AI coach features

# ── CORS ──
# JSON list of allowed origins.
ALLOWED_ORIGINS=["http://localhost:3000"]

# ── Push Notifications (Expo) ──
EXPO_ACCESS_TOKEN=                # Optional — leave empty to send without auth
EXPO_PUSH_URL=https://exp.host/--/api/v2/push/send

# ── Streak ──
MIN_DAILY_MINUTES=10              # Minimum daily minutes to count toward streak
